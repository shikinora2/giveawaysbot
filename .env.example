# =============================================
#   CẤU HÌNH BOT GIVEAWAY - DISCORD
#   (SAO CHÉP FILE NÀY THÀNH .env VÀ ĐIỀN GIÁ TRỊ)
# =============================================

# Token của Bot (lấy tại https://discord.com/developers/applications)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Application ID (lấy tại trang Developer Portal > General Information)
APPLICATION_ID=YOUR_APPLICATION_ID_HERE
